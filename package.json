{
  "name": "quiz-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "ws": "^8.20.0"
  },
  "overrides": {
    "path-to-regexp": "0.1.13"
  },
  "scripts": {
    "start": "vite",
    "server": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm start\"",
    "phone": "npm run build && bash server/scripts/start-phone-server.sh",
    "reset:db": "node server/scripts/reset-db.js",
    "seed:dev": "node server/scripts/seed-dev.js",
    "seed:reset": "npm run reset:db && npm run seed:dev",
    "uploads:cleanup": "node server/scripts/cleanup-orphan-question-images.js",
    "build": "vite build",
    "verify": "node --check server/index.js && node --check server/db.js && vite build",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "lint": "eslint src server --ext .js,.jsx",
    "test:unit": "CI=true jest --runInBand",
    "test:integration": "CI=true RUN_BACKEND_INTEGRATION_TESTS=1 jest --runInBand --runTestsByPath src/server/auth.integration.test.js src/server/quizzes.integration.test.js src/server/live.integration.test.js",
    "test:e2e": "playwright test",
    "test:ci": "npm run lint && npm run test:unit && npm run test:integration && npm run test:e2e",
    "verify:ci": "npm run verify && npm run test:ci",
    "test": "jest --watch"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-jest": "^29.7.0",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-config-react-app": "^7.0.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "vite": "^7.1.10"
  }
}
